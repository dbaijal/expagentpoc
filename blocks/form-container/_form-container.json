  "models": [
    {
      "id": "form-config",
      "fields": [
        {
          "component": "text",
          "name": "field_type",
          "label": "Component",
          "valueType": "string",
          "value": "config"
        },
        {
          "component": "select",
          "name": "field_action",
          "label": "Action Type",
          "description": "Backend integration for form submission",
          "valueType": "string",
          "options": [
            { "name": "Eloqua", "value": "ELOQUA" },
            { "name": "GCMS", "value": "GCMS" },
            { "name": "LSG", "value": "LSG" },
            { "name": "Non-LSG", "value": "NONLSG" },
            { "name": "Marketo", "value": "MARKETO" },
            { "name": "Email", "value": "EMAIL" },
            { "name": "CORA", "value": "CORA" },
            { "name": "Custom API", "value": "API" }
          ]
        },
        {
          "component": "text",
          "name": "config_formid",
          "label": "Form ID",
          "description": "Unique identifier for this form",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "config_redirect",
          "label": "Redirect URL",
          "description": "Page to redirect after successful submission",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "config_thankyou",
          "label": "Thank You Message",
          "description": "Message shown on successful submission (if no redirect)",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "config_steptitles",
          "label": "Wizard Step Titles",
          "description": "Comma-separated step titles for wizard mode (e.g., Contact Info, Preferences, Review). Leave empty for single-page forms.",
          "valueType": "string"
        }
      ]
    },
